rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /documents/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.token.email.matches('.*@entouragelab[.]com');
      allow write: if request.auth != null
                   && request.auth.token.email.matches('.*@entouragelab[.]com');
    }
  }
}
