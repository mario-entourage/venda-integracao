rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSuperAdmin()
          || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/config/superAdmins)
          && request.auth.token.email in get(/databases/$(database)/documents/config/superAdmins).data.emails;
    }

    function isEntourageDomain() {
      return request.auth.token.email.matches('.*@entouragelab[.]com');
    }

    // Returns true if the caller is the creator of the given order document.
    function isOrderOwner(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data.createdById
             == request.auth.uid;
    }

    // Returns true if the caller owns the parent anvisa_request.
    function isAnvisaRequestOwner(requestId) {
      return get(/databases/$(database)/documents/anvisa_requests/$(requestId)).data.ownerEmail
             == request.auth.token.email;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow create: if isSignedIn() && isEntourageDomain() && request.auth.uid == userId;
      // Users can update their own lastLogin/displayName; admins can update anything
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      allow delete: if false;
    }

    match /users/{userId}/profiles/{profileId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow create: if isSignedIn() && isEntourageDomain();
      allow update: if isSignedIn() && isEntourageDomain();
      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow create: if isSignedIn() && isEntourageDomain();
      allow update: if isSignedIn() && isEntourageDomain();
      allow delete: if isAdmin();
    }

    match /representantes/{representanteId} {
      // Legacy collection — read-only for backward compat
      allow read: if isSignedIn() && isEntourageDomain();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if false; // Only admin SDK writes
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientUserId == request.auth.uid;
      allow create: if isSignedIn() && isEntourageDomain();
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin();
    }

    match /stocks/{stockId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin();
    }

    match /stockProducts/{spId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && isEntourageDomain();
      // Any entourage rep may create an order (their uid is recorded as createdById)
      allow create: if isSignedIn() && isEntourageDomain()
        && request.resource.data.createdById == request.auth.uid;
      // Only the order's creator or an admin may update or soft-delete it
      allow update: if isSignedIn() && isEntourageDomain()
        && (resource.data.createdById == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /orders/{orderId}/{subcollection}/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
      // Only the order owner or an admin may write to subcollections
      // (payment/webhook updates go through Admin SDK and bypass these rules)
      allow write: if isSignedIn() && isEntourageDomain()
        && (isOrderOwner(orderId) || isAdmin());
    }

    // ── Collection-group rules (required for collectionGroup() queries) ──────
    // The single-segment wildcard above covers direct subcollection reads, but
    // Firestore collection-group queries need a {path=**} recursive rule so the
    // engine can evaluate the rule for documents at any depth.

    match /{path=**}/payments/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
    }

    match /{path=**}/shipping/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
    }

    match /{path=**}/paymentLinks/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
    }

    // ── Prescriptions ────────────────────────────────────────────────────────

    match /prescriptions/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow create: if isSignedIn() && isEntourageDomain();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isSignedIn() && isEntourageDomain();
    }

    match /medicalSpecialties/{specId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /config/{docId} {
      // Any signed-in user may read config (needed to resolve super-admin list on login).
      allow read: if isSignedIn();
      // Only existing super-admins may write config — this prevents dynamic admins from
      // escalating themselves to super-admin. The circular dependency means the initial
      // config/superAdmins document must be created via Firebase Admin SDK (server-side).
      allow write: if isSuperAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if false;
    }

    match /preregistrations/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /exchangeQuotes/{quoteId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin();
    }

    match /paymentMethods/{pmId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin();
    }

    // ── ANVISA module collections ───────────────────────────────────────

    match /anvisa_requests/{requestId} {
      allow read: if isSignedIn() && isEntourageDomain()
        && (resource.data.ownerEmail == request.auth.token.email || isAdmin());
      allow create: if isSignedIn() && isEntourageDomain();
      allow update: if isSignedIn() && isEntourageDomain()
        && (resource.data.ownerEmail == request.auth.token.email || isAdmin());
      allow delete: if isAdmin();
    }

    match /anvisa_requests/{requestId}/{docType}/{docId} {
      allow read: if isSignedIn() && isEntourageDomain();
      // Subcollection writes are gated on the parent request owner, matching
      // the same owner model the parent document already enforces.
      allow write: if isSignedIn() && isEntourageDomain()
        && (isAnvisaRequestOwner(requestId) || isAdmin());
    }

    match /anvisa_userProfiles/{userId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /anvisa_defaultProfile/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /anvisa_deleted_requests/{requestId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /anvisa_roles_admin/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if false;
    }

    // ── Audit sessions ────────────────────────────────────────────────────
    match /audit_sessions/{sessionId} {
      allow read: if isSignedIn() && isEntourageDomain();
      allow create: if isAdmin();
      allow update: if isSignedIn() && isEntourageDomain();
      allow delete: if false;
    }

    // ── Operation audit log (Zero Anonymous Actions) ──────────────────────
    match /audit_log/{entryId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isEntourageDomain()
                    && request.resource.data.performedById == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
  }
}
